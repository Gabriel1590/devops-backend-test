# Copy this file to .env and fill in values for local development.
# docker compose up -d provides Elasticsearch — other values below work out of the box.

# Elasticsearch (matches docker-compose.yml defaults)
ES_URL=http://localhost:9200
ES_USERNAME=elastic
ES_PASSWORD=elastic

# Stage — controls index name suffixes (e.g. evaluation_tenant-a_dev)
STAGE=dev

# Tenant for local testing
TENANT_ID=tenant-a

# LLM stub version: 'v1' (default) or 'v2' (used in incident-2 debugging scenario)
LLM_API_VERSION=v1

# LLM model name — in production this comes from SSM at runtime.
# Locally we set it directly so the SSM call is skipped.
LLM_MODEL_NAME=gemini-1.5-pro

# Slack webhook URL — optional, only needed for the stretch goal
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# S3 bucket — for local testing via trigger-local.ts, S3 is mocked from disk.
# Set this to the bucket name your Lambda would receive in the S3 event.
INGEST_BUCKET=companyx-ingest-tenant-a-dev
